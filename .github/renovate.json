{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended"
	],
	"automerge": true,
	"git-submodules": {
		"enabled": true
	},
	"packageRules": [
		{
			"groupName": "minver",
			"matchPackageNames": [
				"minver",
				"minver-cli"
			]
		},
		{
			"matchPackageNames": ["dotnet-sdk"],
			"versioning": "same-major"
		},
		{
			"groupName": "dotnet",
			"matchPackageNames": [
				"dotnet-sdk",
				"mcr.microsoft.com/devcontainers/dotnet"
			]
		}
	]
}
